# Copy this file to .env and fill in real values. Never commit the real .env.

# Same Supabase project the rag-pipeline package writes to/reads from
# (Project Settings -> API in the Supabase dashboard). Use the service_role
# key, not the anon key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# OpenAI API key used both for text-embedding-3-small (via rag_pipeline) and
# to synthesize answers from retrieved chunks in POST /query (via the
# gpt-5 chat model - see rag_api/config.py).
OPENAI_API_KEY=sk-your-openai-api-key

# Pre-shared secret this service requires as the `X-Internal-Api-Key` header
# on every route except /healthz (see rag_api/auth.py). This service's ALB is
# public (fronted by CloudFront, not an internal/private ALB), so there is no
# network isolation to rely on - this header is the primary (and only)
# access control for this service. Generate a long random value, e.g.
# `openssl rand -hex 32`, and configure the frontend's RAG_API_INTERNAL_KEY
# with the same value.
INTERNAL_API_KEY=a-long-random-shared-secret
