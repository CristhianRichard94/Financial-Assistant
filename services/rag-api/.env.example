# Copy this file to .env and fill in real values. Never commit the real .env.

# Same Supabase project the rag-pipeline package writes to/reads from
# (Project Settings -> API in the Supabase dashboard). Use the service_role
# key, not the anon key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# OpenAI API key used for text-embedding-3-small (via rag_pipeline).
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API key used to synthesize answers from retrieved chunks in
# POST /query.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Pre-shared secret this service requires as the `X-Internal-Api-Key` header
# on every route except /healthz (see rag_api/auth.py). This is
# defense-in-depth on top of network isolation (an internal ALB in
# production) - generate a long random value, e.g. `openssl rand -hex 32`,
# and configure the frontend's RAG_API_INTERNAL_KEY with the same value.
INTERNAL_API_KEY=a-long-random-shared-secret
