# Copy this file to .env and fill in real values. Never commit the real .env.

# Supabase project settings (Project Settings -> API in the Supabase dashboard).
# Use the service_role key here, not the anon key: ingestion runs as a
# trusted backend job and needs to bypass row-level security to write.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# OpenAI API key used for text-embedding-3-small.
OPENAI_API_KEY=sk-your-openai-api-key
