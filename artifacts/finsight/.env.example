# Copy this file to .env.local and fill in real values. Never commit the
# real .env.local.

# Base URL of the rag-api service (services/rag-api). Used server-side only
# by src/lib/ragApiClient.ts - never exposed to the browser. For local
# development, run rag-api with `uvicorn rag_api.main:app --reload --port
# 8000` (see services/rag-api/README.md) and point this at it:
RAG_API_BASE_URL=http://localhost:8000

# Must match rag-api's own INTERNAL_API_KEY (see
# services/rag-api/.env.example) - sent as the X-Internal-Api-Key header on
# every request. Used server-side only, never exposed to the browser.
RAG_API_INTERNAL_KEY=a-long-random-shared-secret

# Same Supabase project rag-pipeline/rag-api write to (Project Settings ->
# API in the Supabase dashboard). These are both client-safe by design and
# are used by *both* the browser Supabase client
# (src/lib/supabase/browser.ts, e.g. the login page's Google sign-in button
# and AppLayout's log-out action) and the server Supabase client
# (src/lib/supabase/server.ts, src/lib/supabase/middleware.ts) - use the
# anon/public key here, never the service_role key.
#
# No Supabase service-role key is needed anywhere in this Next.js app:
# - chat_messages (src/app/api/chat/messages/route.ts) is read/written using
#   the signed-in user's own session (anon key + cookies) - Postgres Row
#   Level Security policies on that table are what scope access to the
#   current user, not application code (see
#   services/rag-pipeline/sql/009_create_chat_messages_table.sql).
# - rag-api calls (src/lib/ragApiClient.ts) are authorized via the existing
#   RAG_API_INTERNAL_KEY shared secret above plus the X-User-Id header
#   (the verified session's Supabase auth.users.id) - never a Supabase key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
